# Global
EXTRA_FILES=https://github.com/ReVanced/GmsCore/releases/latest@Revanced-Microg.apk
PATCH_APPS=YOUTUBE_MORPHE,YOUTUBE_ANDEA,YOUTUBE_MUSIC_MORPHE,YOUTUBE_MUSIC_ANDEA,YOUTUBE_REVANCED,YOUTUBE_MUSIC_REVANCED,TWITTER_PIKO,INSTAGRAM_PIKO
GLOBAL_CLI_DL=https://github.com/revanced/revanced-cli/releases/latest
GLOBAL_PATCHES_DL=https://api.revanced.app/v5/patches.rvp
# ReVanced's current release is CLI v6, so the global profile must emit v6 argument names.
GLOBAL_CLI_ARGSF=revanced-cli

# YouTube (Using MORPHE Patches)
YOUTUBE_MORPHE_DL_SOURCE=https://www.apkmirror.com/apk/google-inc/youtube/
YOUTUBE_MORPHE_PATCHES_DL=https://github.com/MorpheApp/morphe-patches/releases/latest-prerelease
YOUTUBE_MORPHE_CLI_DL=https://github.com/MorpheApp/morphe-cli
YOUTUBE_MORPHE_CLI_ARGSF=morphe-cli
YOUTUBE_MORPHE_EXCLUDE_PATCH=custom-branding-icon-youtube,custom-branding-name-youtube,enable-debug-logging,hide-fullscreen-button,custom-branding-icon-for-youtube,custom-branding-name-for-youtube,custom-branding
YOUTUBE_MORPHE_INCLUDE_PATCH=change-package-name
YOUTUBE_MORPHE_PACKAGE_NAME=com.google.android.youtube
YOUTUBE_MORPHE_OPTIONS_FILE=options_yt_morphe.json

# YouTube (Using anddea Patches)
YOUTUBE_ANDEA_DL_SOURCE=https://www.apkmirror.com/apk/google-inc/youtube/
YOUTUBE_ANDEA_PATCHES_DL=https://github.com/anddea/revanced-patches/releases/latest-prerelease
# Current anddea MPP bundles depend on Morphe patcher classes, so pair them with Morphe CLI.
YOUTUBE_ANDEA_CLI_DL=https://github.com/MorpheApp/morphe-cli
YOUTUBE_ANDEA_CLI_ARGSF=morphe-cli
YOUTUBE_ANDEA_EXCLUDE_PATCH=custom-branding-icon-youtube,custom-branding-name-youtube,enable-debug-logging,hide-fullscreen-button,custom-branding-icon-for-youtube,custom-branding-name-for-youtube
YOUTUBE_ANDEA_PACKAGE_NAME=com.google.android.youtube


# YouTube (Using ReVanced Patches)
YOUTUBE_REVANCED_DL_SOURCE=https://www.apkmirror.com/apk/google-inc/youtube/
YOUTUBE_REVANCED_PATCHES_DL=https://api.revanced.app/v5/patches.rvp
# ReVanced API bundles require the v6 verification-aware patch input syntax.
YOUTUBE_REVANCED_CLI_ARGSF=revanced-cli
YOUTUBE_REVANCED_EXCLUDE_PATCH=custom-branding-icon-youtube,custom-branding-name-youtube,enable-debug-logging,hide-fullscreen-button,custom-branding-icon-for-youtube,custom-branding-name-for-youtube
YOUTUBE_REVANCED_PACKAGE_NAME=com.google.android.youtube

# YouTube Music (Using MORPHE Patches)
YOUTUBE_MUSIC_MORPHE_DL_SOURCE=https://www.apkmirror.com/apk/google-inc/youtube-music/
YOUTUBE_MUSIC_MORPHE_PATCHES_DL=https://github.com/MorpheApp/morphe-patches/releases/latest-prerelease
YOUTUBE_MUSIC_MORPHE_CLI_DL=https://github.com/MorpheApp/morphe-cli
YOUTUBE_MUSIC_MORPHE_CLI_ARGSF=morphe-cli
YOUTUBE_MUSIC_MORPHE_EXCLUDE_PATCH=custom-branding-icon-youtube-music,custom-branding-name-youtube-music,enable-compact-dialog,enable-debug-logging,enable-old-player-layout,custom-branding-icon-for-youtube-music,custom-branding-name-for-youtube-music,custom-header-for-youtube-music,custom-branding
YOUTUBE_MUSIC_MORPHE_PACKAGE_NAME=com.google.android.apps.youtube.music
YOUTUBE_MUSIC_MORPHE_INCLUDE_PATCH=change-package-name
YOUTUBE_MUSIC_MORPHE_OPTIONS_FILE=options_yt_music_morphe.json

# YouTube Music (Using anddea Patches)
YOUTUBE_MUSIC_ANDEA_DL_SOURCE=https://www.apkmirror.com/apk/google-inc/youtube-music/
YOUTUBE_MUSIC_ANDEA_PATCHES_DL=https://github.com/anddea/revanced-patches/releases/latest-prerelease
# Current anddea MPP bundles depend on Morphe patcher classes, so pair them with Morphe CLI.
YOUTUBE_MUSIC_ANDEA_CLI_DL=https://github.com/MorpheApp/morphe-cli
YOUTUBE_MUSIC_ANDEA_CLI_ARGSF=morphe-cli
YOUTUBE_MUSIC_ANDEA_EXCLUDE_PATCH=custom-branding-icon-youtube-music,custom-branding-name-youtube-music,enable-compact-dialog,enable-debug-logging,enable-old-player-layout,custom-branding-icon-for-youtube-music,custom-branding-name-for-youtube-music,custom-header-for-youtube-music
YOUTUBE_MUSIC_ANDEA_PACKAGE_NAME=com.google.android.apps.youtube.music


# YouTube Music (Using ReVanced Patches)
YOUTUBE_MUSIC_REVANCED_DL_SOURCE=https://www.apkmirror.com/apk/google-inc/youtube-music/
YOUTUBE_MUSIC_REVANCED_PATCHES_DL=https://api.revanced.app/v5/patches.rvp
# ReVanced API bundles require the v6 verification-aware patch input syntax.
YOUTUBE_MUSIC_REVANCED_CLI_ARGSF=revanced-cli
YOUTUBE_MUSIC_REVANCED_EXCLUDE_PATCH=custom-branding-icon-youtube-music,custom-branding-name-youtube-music,enable-compact-dialog,enable-debug-logging,enable-old-player-layout,custom-branding-icon-for-youtube-music,custom-branding-name-for-youtube-music,custom-header-for-youtube-music
YOUTUBE_MUSIC_REVANCED_PACKAGE_NAME=com.google.android.apps.youtube.music

# X/Twitter (Using Piko/Morphe Patches)
# Leave VERSION unset so the builder uses Piko's current compatible X/Twitter version from list-patches.
TWITTER_PIKO_DL_SOURCE=https://www.apkmirror.com/apk/x-corp/twitter/
TWITTER_PIKO_PATCHES_DL=https://github.com/crimera/piko/releases/latest-prerelease
TWITTER_PIKO_CLI_DL=https://github.com/MorpheApp/morphe-cli
TWITTER_PIKO_CLI_ARGSF=morphe-cli
TWITTER_PIKO_PACKAGE_NAME=com.twitter.android

# Instagram (Using Piko/Morphe Patches)
# Leave VERSION unset so the builder uses Piko's current compatible Instagram version from list-patches.
INSTAGRAM_PIKO_DL_SOURCE=https://www.apkmirror.com/apk/instagram/instagram-instagram/
INSTAGRAM_PIKO_PATCHES_DL=https://github.com/crimera/piko/releases/latest-prerelease
INSTAGRAM_PIKO_CLI_DL=https://github.com/MorpheApp/morphe-cli
INSTAGRAM_PIKO_CLI_ARGSF=morphe-cli
INSTAGRAM_PIKO_PACKAGE_NAME=com.instagram.android

#Spotify
SPOTIFY_PATCHES_DL=https://github.com/anddea/revanced-patches/releases/latest-prerelease
SPOTIFY_PACKAGE_NAME=com.spotify.music
